# Internal design documents — NOT for public consumption.
# These are SDD/spec documents meant for internal development only.
# To remove from git history entirely, use:
#   git filter-repo --path docs/ --invert-paths
#   git filter-repo --path .atl/ --invert-paths
#   git filter-repo --path verify/ --invert-paths
#   git filter-repo --path signpath/ --invert-paths
# Then force-push. See https://github.com/newren/git-filter-repo
